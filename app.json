{
  "expo": {
    "name": "Mileage Calculator",
    "slug": "milage-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mipmap-xxxhdpi/ic_launcher.png",
    "scheme": "milageapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/mipmap-xxxhdpi/ic_launcher.png",
      "imageWidth": 200,
      "resizeMode": "contain",
      "backgroundColor": "#09090E"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/mipmap-xxxhdpi/ic_launcher.png"
    },
    "android": {
      "icon": "./assets/images/mipmap-xxxhdpi/ic_launcher.png",
      "adaptiveIcon": {
        "backgroundColor": "#09090E",
        "foregroundImage": "./assets/images/mipmap-xxxhdpi/ic_launcher.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.asifansari.mileagecalculator"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/mipmap-hdpi/ic_launcher.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/mipmap-xxxhdpi/ic_launcher.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#09090E",
          "dark": {
            "backgroundColor": "#09090E"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0c690448-dbf3-412b-9383-c36a8883c23c"
      }
    },
    "owner": "asif01devv"
  }
}
